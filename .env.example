# Environment Variables for ClinicalPilot
# Copy this file to .env and fill in your values
#
# NOTE: Model engines & per-agent routing are now configured in config/models.json
# (edit live in the Settings tab). API keys resolve: hardcoded (config/secrets.local.py
# or the vars below) -> entered in the UI -> asked on demand. Any var below that matches
# a profile's api_key_ref (e.g. GROQ_API_KEY, OPENAI_API_KEY) is treated as hardcoded.

# ========================
# REQUIRED
# ========================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ========================
# LLM Configuration
# ========================
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# Local LLM (Optional — MedGemma via Ollama)
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=medgemma2:9b

# ========================
# PubMed / NCBI
# ========================
NCBI_EMAIL=your-email@example.com
NCBI_API_KEY=

# ========================
# Observability (Optional)
# ========================
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=clinicalpilot

# ========================
# Groq (AI Chat Assistant)
# ========================
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ========================
# FDA API (Optional)
# ========================
FDA_API_KEY=

# ========================
# Application Settings
# ========================
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]
EMERGENCY_TIMEOUT_SEC=5
MAX_DEBATE_ROUNDS=1

# ========================
# Data Paths
# ========================
LANCEDB_PATH=data/lancedb
DRUGBANK_CSV_PATH=data/drugbank/drugbank_vocabulary.csv

# ========================
# SpaCy Model (for Presidio PHI scrubbing)
# en_core_web_sm (~12MB, default) keeps memory low for free-tier hosting.
# Use en_core_web_lg (~560MB) only on a host with plenty of RAM.
# ========================
SPACY_MODEL=en_core_web_sm
