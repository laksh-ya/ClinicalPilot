# Environment Variables for ClinicalPilot
# Copy this file to .env and fill in your values

# ========================
# REQUIRED
# ========================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ========================
# LLM Configuration
# ========================
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# Local LLM (Optional — MedGemma via Ollama)
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=medgemma2:9b

# ========================
# PubMed / NCBI
# ========================
NCBI_EMAIL=your-email@example.com
NCBI_API_KEY=

# ========================
# Observability (Optional)
# ========================
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=clinicalpilot

# ========================
# FDA API (Optional)
# ========================
FDA_API_KEY=

# ========================
# Application Settings
# ========================
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]
EMERGENCY_TIMEOUT_SEC=5
MAX_DEBATE_ROUNDS=3

# ========================
# Data Paths
# ========================
LANCEDB_PATH=data/lancedb
DRUGBANK_CSV_PATH=data/drugbank/drugbank_vocabulary.csv

# ========================
# SpaCy Model (for Presidio)
# ========================
SPACY_MODEL=en_core_web_lg
